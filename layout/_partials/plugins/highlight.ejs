<%
if (theme.code.highlight.lib === 'prismjs') {
  if (!theme.code.highlight.prismjs.preprocess) {
    import_js(theme.static_prefix.prismjs, theme.static_suffix.js.prismjs.core)
    import_js(theme.static_prefix.prismjs, theme.static_suffix.js.prismjs.autoloader)
  }

  if (theme.code.highlight.line_number) {
    import_css(theme.static_prefix.prismjs, theme.static_suffix.css.prismjs.line_numbers)
    import_js(theme.static_prefix.prismjs, theme.static_suffix.js.prismjs.line_numbers)
  }
}
%>
