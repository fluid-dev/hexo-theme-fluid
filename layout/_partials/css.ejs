<%- css_ex(theme.static_prefix.bootstrap, theme.static_suffix.css.bootstrap) %>

<% var css_snippets = deduplicate(page.css_snippets) %>
<% for (var idx = 0; idx < css_snippets.length; idx++) { %>
  <%- css_snippets[idx] %>
<% } %>
<% page.css_snippets = [] %>

<!-- 主题依赖的图标库，不要自行修改 -->
<!-- Do not modify the link that theme dependent icons -->
<%- css('//at.alicdn.com/t/c/font_1749284_5i9bdhy70f8.css') %>

<%- css(theme.static_prefix.iconfont || theme.iconfont) %>

<%- css_ex(theme.static_prefix.internal_css, theme.static_suffix.css.internal.main) %>

<% if (theme.code.highlight.enable) { %>
  <%- css_ex(theme.static_prefix.internal_css, theme.static_suffix.css.internal.highlight, 'id="highlight-css"') %>
  <% if (theme.dark_mode.enable) { %>
    <%- css_ex(theme.static_prefix.internal_css, theme.static_suffix.css.internal.highlight_dark, 'id="highlight-css-dark"') %>
  <% } %>
<% } %>

<% if (theme.custom_css) { %>
  <%- css(theme.custom_css) %>
<% } %>
